  {
    "id": "pihub_execute_command",
    "type": "function",
    "z": "pihub_cloud_bridge_tab",
    "name": "Execute Pump/MQTT Command",
    "func": "var cmd = msg.payload && msg.payload.command;\nif (!cmd || !cmd.id) return null;\nvar kind = cmd.kind;\nvar p = cmd.payload || {};\nvar result = { id: cmd.id, ok: true, result: { handled_by: 'nodered', kind: kind } };\n\nif (kind === 'plugin_manual') {\n    var action = (p.action === 'off') ? 'OFF' : 'ON';\n    var minutes = Number(p.minutes || 10);\n    var mqtt = {\n        topic: env.get('MQTT_COMMAND_TOPIC') || 'cmnd/zisterne/POWER',\n        payload: action,\n        _pihubCommandId: cmd.id\n    };\n    result.result.action = action;\n    result.result.minutes = minutes;\n    result.result.topic = mqtt.topic;\n    return [mqtt, { payload: result }];\n}\n\nif (kind === 'mqtt_publish') {\n    var topic = String(p.topic || '');\n    if (!topic) return [null, { payload: { id: cmd.id, ok: false, result: { error: 'missing topic' } } }];\n    var mqtt2 = { topic: topic, payload: String(p.payload || ''), _pihubCommandId: cmd.id };\n    result.result.topic = topic;\n    return [mqtt2, { payload: result }];\n}\n\nreturn [null, { payload: { id: cmd.id, ok: false, result: { error: 'unsupported command for Node-RED runner: ' + kind } } }];",
    "outputs": 2,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1200,
    "y": 620,
    "wires": [
      [
        "pihub_mqtt_out"
      ],
      [
        "pihub_build_result"
      ]
    ]
  },
