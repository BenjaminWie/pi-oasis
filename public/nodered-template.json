[
  {
    "id": "pihub_cloud_bridge_tab",
    "type": "tab",
    "label": "Pi-Hub Cloud Bridge",
    "disabled": false,
    "info": "Working Pi-Hub bridge. Configure tab env values from the Pi UI /integrations. HTTP nodes intentionally use method=use, url empty, authType empty so msg.url/msg.headers are honored.",
    "env": [
      {
        "name": "CLOUD_BRIDGE_URL",
        "type": "str",
        "value": "https://pi-hub.benniwie.com/api/public/cloud-bridge/event"
      },
      {
        "name": "CLOUD_STRATEGY_URL",
        "type": "str",
        "value": "https://pi-hub.benniwie.com/api/public/cloud-bridge/strategy"
      },
      {
        "name": "CLOUD_COMMAND_POLL_URL",
        "type": "str",
        "value": "https://pi-hub.benniwie.com/api/public/agent/poll?runner=nodered"
      },
      {
        "name": "CLOUD_COMMAND_RESULT_URL",
        "type": "str",
        "value": "https://pi-hub.benniwie.com/api/public/agent/result"
      },
      {
        "name": "CLOUD_DEVICE_TOKEN",
        "type": "str",
        "value": ""
      },
      {
        "name": "LOCAL_API_URL",
        "type": "str",
        "value": "http://127.0.0.1:3000/api/public/ingest/event"
      },
      {
        "name": "PI_INGEST_TOKEN",
        "type": "str",
        "value": ""
      },
      {
        "name": "DEFAULT_DEVICE_LABEL",
        "type": "str",
        "value": "drainpress"
      },
      {
        "name": "MQTT_COMMAND_TOPIC",
        "type": "str",
        "value": "cmnd/zisterne/POWER"
      },
      {
        "name": "MQTT_BROKER_HOST",
        "type": "str",
        "value": "mosquitto"
      },
      {
        "name": "MQTT_BROKER_PORT",
        "type": "num",
        "value": "1883"
      }
    ]
  },
