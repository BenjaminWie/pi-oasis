  {
    "id": "pihub_build_local_fallback",
    "type": "function",
    "z": "pihub_cloud_bridge_tab",
    "name": "Build Local Fallback Request",
    "func": "var original = msg._pihubOriginalPayload || msg.payload || {};\nmsg.payload = original;\nif (!msg.payload.component) msg.payload.component = 'node_red_fallback';\nif (!msg.payload.status) msg.payload.status = 'warning';\nif (!msg.payload.ts) msg.payload.ts = new Date().toISOString();\nmsg.method = 'POST';\nmsg.url = env.get('LOCAL_API_URL') || 'http://127.0.0.1:3000/api/public/ingest/event';\nmsg.headers = { 'Content-Type': 'application/json' };\nvar localToken = env.get('PI_INGEST_TOKEN') || '';\nif (localToken) msg.headers.Authorization = 'Bearer ' + localToken;\nnode.status({fill:'yellow', shape:'ring', text:'cloud failed -> local RAM fallback'});\nnode.warn('Cloud-Bridge nicht erreichbar oder 401. Sende lokal als RAM-Fallback. Prüfe CLOUD_DEVICE_TOKEN, nicht Revocation/Factory Token.');\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1280,
    "y": 220,
    "wires": [
      [
        "pihub_http_local"
      ]
    ]
  },
