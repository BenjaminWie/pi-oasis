  {
    "id": "pihub_build_cloud",
    "type": "function",
    "z": "pihub_cloud_bridge_tab",
    "name": "Build Cloud Event Request",
    "func": "var token = env.get('CLOUD_DEVICE_TOKEN') || '';\nif (!token) {\n    node.status({fill:'red', shape:'ring', text:'CLOUD_DEVICE_TOKEN fehlt'});\n    node.error('CLOUD_DEVICE_TOKEN fehlt. In Pi-Hub /integrations anzeigen und in Node-RED Tab-Env eintragen.', msg);\n    return null;\n}\nvar payload = msg.payload || {};\nif (!payload.component) payload.component = 'node_red';\nif (!payload.status) payload.status = 'info';\nif (!payload.ts) payload.ts = new Date().toISOString();\nif (!payload.device) payload.device = env.get('DEFAULT_DEVICE_LABEL') || 'drainpress';\nmsg.payload = payload;\nmsg._pihubOriginalPayload = JSON.parse(JSON.stringify(payload));\nmsg.method = 'POST';\nmsg.url = env.get('CLOUD_BRIDGE_URL');\nmsg.headers = {\n    'Authorization': 'Bearer ' + token,\n    'Content-Type': 'application/json'\n};\nnode.status({fill:'blue', shape:'dot', text:'send cloud'});\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 600,
    "y": 180,
    "wires": [
      [
        "pihub_http_cloud"
      ]
    ]
  },
