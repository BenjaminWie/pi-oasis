  {
    "id": "pihub_store_strategy",
    "type": "function",
    "z": "pihub_cloud_bridge_tab",
    "name": "Store Strategy",
    "func": "if (msg.statusCode >= 200 && msg.statusCode < 300 && msg.payload && msg.payload.params) {\n    global.set('zisterne_strategy', msg.payload.params);\n    global.set('zisterne_eco_paused', msg.payload.eco_paused === true);\n    node.status({fill:'green', shape:'dot', text:'strategy updated'});\n} else {\n    node.status({fill:'yellow', shape:'ring', text:'strategy failed ' + msg.statusCode});\n    node.warn(msg.payload || msg.error || 'Strategy poll failed');\n}\nreturn null;",
    "outputs": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 890,
    "y": 460,
    "wires": []
